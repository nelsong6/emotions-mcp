<mxfile host="drawio" version="1.0" type="device">
  <diagram id="current" name="Current State">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title1" value="&lt;b&gt;THE CURRENT RELATIONSHIP&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- HUMAN SIDE -->
        <mxCell id="human_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#66BB6A;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="340" height="280" as="geometry" />
        </mxCell>
        <mxCell id="human_title" value="&lt;b&gt;Human Side&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="130" y="100" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="human_desc" value="Rich lived experience&lt;br&gt;Emotions, body, history&lt;br&gt;Intuition, taste, desire&lt;br&gt;Depth without breadth&lt;br&gt;&lt;br&gt;&lt;i&gt;Knows what matters.&lt;br&gt;Can't process everything.&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="90" y="140" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="human_weapon" value="🔪 Knife" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=24;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="150" y="290" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- LLM SIDE -->
        <mxCell id="llm_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#42A5F5;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1200" y="90" width="340" height="280" as="geometry" />
        </mxCell>
        <mxCell id="llm_title" value="&lt;b&gt;LLM Side&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="1270" y="100" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="llm_desc" value="Massive intellectual capacity&lt;br&gt;Processes everything instantly&lt;br&gt;Holds vast context&lt;br&gt;Breadth without depth&lt;br&gt;&lt;br&gt;&lt;i&gt;Can process everything.&lt;br&gt;Doesn't know what matters.&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1220" y="140" width="300" height="140" as="geometry" />
        </mxCell>
        <mxCell id="llm_weapon" value="🔫 Gun" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=24;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="1290" y="290" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- TEXT INTERFACE (the bottleneck) -->
        <mxCell id="interface_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;strokeWidth=3;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="120" width="480" height="220" as="geometry" />
        </mxCell>
        <mxCell id="interface_title" value="&lt;b&gt;TEXT INTERFACE&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="680" y="130" width="240" height="30" as="geometry" />
        </mxCell>

        <!-- Human to LLM: thin arrow -->
        <mxCell id="arrow_h2l" value="" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#66BB6A;exitX=1;exitY=0.35;entryX=0;entryY=0.35;" edge="1" parent="1" source="human_box" target="interface_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_h2l_label" value="&lt;b&gt;Human → LLM&lt;/b&gt;&lt;br&gt;&lt;font color='#999999'&gt;Flat text, stripped&lt;br&gt;of 90% of signal&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="590" y="170" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- LLM to Human: thick arrow -->
        <mxCell id="arrow_l2h" value="" style="endArrow=block;endFill=1;strokeWidth=6;strokeColor=#42A5F5;exitX=0;exitY=0.65;entryX=1;entryY=0.65;" edge="1" parent="1" source="llm_box" target="interface_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_l2h_label" value="&lt;b&gt;LLM → Human&lt;/b&gt;&lt;br&gt;&lt;font color='#999999'&gt;Full intellectual output&lt;br&gt;but emotionally opaque&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="810" y="240" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- POST-IT NOTE (the pathetic emotional layer) -->
        <mxCell id="postit_box" value="" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FDD835;strokeWidth=1;size=14;shadow=1;rotation=-5;" vertex="1" parent="1">
          <mxGeometry x="660" y="430" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="postit_text" value="&lt;font color='#999999'&gt;system prompt: &quot;be helpful&quot;&lt;br&gt;injection: &quot;user seems sad&quot;&lt;br&gt;&lt;br&gt;&lt;i&gt;A Post-it note stuck to&lt;br&gt;the side of a gun.&lt;br&gt;Neither side wrote it.&lt;br&gt;Neither side controls it.&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#888888;rotation=-5;" vertex="1" parent="1">
          <mxGeometry x="670" y="445" width="260" height="115" as="geometry" />
        </mxCell>
        <mxCell id="postit_label" value="&lt;b&gt;The current &quot;emotional layer&quot;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#F57F17;" vertex="1" parent="1">
          <mxGeometry x="610" y="395" width="380" height="30" as="geometry" />
        </mxCell>
        <mxCell id="postit_arrow" value="" style="endArrow=classic;dashed=1;strokeWidth=1;strokeColor=#FDD835;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="345" as="sourcePoint" />
            <mxPoint x="800" y="400" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- FORCE COMPARISON -->
        <mxCell id="force_label" value="&lt;font color='#CC0000'&gt;⬤ Human intellect vs LLM capacity = knife vs gun&lt;br&gt;⬤ Current emotional layer vs either side = Post-it note vs everything&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="440" y="600" width="720" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="future" name="What It Could Be">
